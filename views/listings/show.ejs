<% layout("/layouts/boilerplate") %>

<style>
  .center-container {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    text-align: center;
    margin-top: 30px;
  }

  .card {
    margin-top: 20px;
    padding: 20px;
  }

  .card-img-top {
    object-fit: cover;
    height: 20rem;
  }

  form {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  hr {
    margin: 40px 0;
  }

  .btn:hover {
    opacity: 0.9;
  }
</style>

<div class="container center-container">
  <h1><%= listings.title %></h1>

  <div class="card col-md-8">
    <img
      src="<%= listings.image %>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body"></div>

    <ul>
      <li><%= listings.description %></li>
      <li>
        &#8377; <%= listings.price ? listings.price.toLocaleString("en-IN") :
        "Not available" %>
      </li>
      <li><%= listings.location %></li>
      <li><%= listings.country %></li>
    </ul>

    <% if(currentUser && currentUser._id.equals(listings.owner._id)) { %>
     
  <div class="btns">
    <a href="/listings/<%= listings._id %>/edit" class="btn btn-dark mb-3">Edit this listing</a>

    <form method="POST" action="/listings/<%= listings._id %>?_method=DELETE">
      <button class="btn btn-dark mb-3">Delete</button>
    </form>
  </div>
  <% }%>



  </div>

  <hr style="width: 100%; max-width: 600px" />

  <h4>Leave a Review</h4>
  <form
    action="/listings/<%= listings._id %>/reviews"
    method="POST"
    novalidate
    class="needs-validation"
  >
  <fieldset class="starability-slot">
  <legend>First rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="rating" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="rating" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="rating" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="rating" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="rating" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>

    <div class="mb-3">
      <label for="rating" class="form-label">Rating</label>
      <input
        type="range"
        id="rating"
        class="form-range"
        name="review[rating]"
        min="1"
        max="5"
      />
    </div>
    <div class="mb-3">
      <label for="comment" class="form-label">Comments</label>
      <textarea
        name="review[comment]"
        id="comment"
        class="form-control"
        cols="30"
        rows="5"
        required
      ></textarea>
    </div>
    <button class="btn btn-outline-dark">Submit</button>
  </form>
  <hr>
<h4 class="my-3">All Reviews</h4>
<div class="row">
  <% for (let review of listings.reviews) { %>
    <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
      <div class="card h-100 shadow-sm" style="max-height: 220px; overflow: auto;">
        <div class="card-body p-3">
          <h6 class="card-title mb-2">Rating: <%= review.rating %> ⭐</h6>
          <p class="card-text small">"<%= review.comment %>"</p>
          
        </div>
        <div>
          <form class="mb-3" action="/listings/<%= listings._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
  <button class="btn btn-sm btn-dark">Delete</button>
</form>

        </div>
      </div>
    </div>
  <% } %>
</div>

</div>

</div>
